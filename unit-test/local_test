#!/bin/bash
## -*- mode: bash; indent-tabs-mode: nil; perl-indent-level: 4 -*-
## vim: autoindent tabstop=4 shiftwidth=4 expandtab softtabstop=4 filetype=bash

# Standalone Redfish connection and power collection test
# Usage: local_test <ip_address> [username] [password]

ip=$1
username=${2:-"root"}
password=${3:-""}

# Parameter validation
if [ -z "$ip" ]; then
    echo "ERROR: IP address required"
    echo "Usage: $0 <ip_address> [username] [password]"
    echo "Example: $0 192.168.1.10 admin mypassword"
    exit 1
fi

if [ -z "$password" ]; then
    echo "ERROR: Password required"
    echo "Usage: $0 <ip_address> [username] [password]"
    exit 1
fi

# Prerequisites check
if ! command -v curl &> /dev/null; then
    echo "ERROR: curl not found (required for HTTPS REST API calls)"
    exit 1
fi

if ! command -v jq &> /dev/null; then
    echo "ERROR: jq not found (required for JSON parsing)"
    exit 1
fi

echo "========================================="
echo "Redfish Power Collection Test"
echo "========================================="
echo "Target IP: $ip"
echo "Username: $username"
echo "Password: <redacted>"
echo ""

# Step 1: Test basic connectivity
echo "[1/5] Testing basic Redfish connectivity..."
if ! curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "https://$ip/redfish/v1/" > /dev/null 2>&1; then
    echo "  ✗ FAILED: Cannot connect to Redfish endpoint at $ip"
    echo ""
    echo "Troubleshooting:"
    echo "  - Verify IP address is correct"
    echo "  - Check network connectivity: ping $ip"
    echo "  - Ensure BMC is powered on and Redfish service is running"
    echo "  - Verify credentials are correct"
    exit 1
fi
echo "  ✓ Connection successful"
echo ""

# Step 2: Get Redfish service root
echo "[2/5] Querying Redfish service root..."
service_root=$(curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "https://$ip/redfish/v1/" 2>&1)
if [ $? -ne 0 ]; then
    echo "  ✗ FAILED: Could not query service root"
    exit 1
fi

redfish_version=$(echo "$service_root" | jq -r '.RedfishVersion // "Unknown"' 2>/dev/null)
service_name=$(echo "$service_root" | jq -r '.Name // "Unknown"' 2>/dev/null)
echo "  Service: $service_name"
echo "  Redfish Version: $redfish_version"
echo ""

# Step 3: Get chassis list
echo "[3/5] Querying chassis list..."
chassis_response=$(curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "https://$ip/redfish/v1/Chassis" 2>&1)
if [ $? -ne 0 ]; then
    echo "  ✗ FAILED: Could not query chassis list"
    exit 1
fi

chassis_count=$(echo "$chassis_response" | jq -r '.Members | length' 2>/dev/null)
echo "  Found $chassis_count chassis"

# Extract first chassis ID
chassis_id=$(echo "$chassis_response" | jq -r '.Members[0]."@odata.id"' 2>/dev/null | sed 's|.*/||')
if [ -z "$chassis_id" ] || [ "$chassis_id" == "null" ]; then
    echo "  ✗ FAILED: Could not determine chassis ID"
    exit 1
fi
echo "  Using Chassis ID: $chassis_id"
echo ""

# Step 4: Test Standard Power endpoint
echo "[4/7] Testing Standard Redfish Power endpoint..."
power_url="https://$ip/redfish/v1/Chassis/$chassis_id/Power"
echo "  URL: $power_url"

power_data=$(curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "$power_url" 2>&1)
power_endpoint_works=false

if [ $? -ne 0 ]; then
    echo "  ✗ Power endpoint not accessible"
else
    # Check if we got valid JSON
    if ! echo "$power_data" | jq empty 2>/dev/null; then
        echo "  ✗ Invalid JSON response from Power endpoint"
    else
        echo "  ✓ Power endpoint accessible"
        power_endpoint_works=true
    fi
fi
echo ""

# Step 5: Test BF-3 Sensor-based API
echo "[5/7] Testing BF-3 Sensor-based API..."
sensor_url="https://$ip/redfish/v1/Chassis/Card1/Sensors"
echo "  URL: $sensor_url"

sensor_list=$(curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "$sensor_url" 2>&1)
sensor_endpoint_works=false

if [ $? -ne 0 ]; then
    echo "  ✗ Sensor endpoint not accessible"
else
    # Check if we got valid JSON
    if ! echo "$sensor_list" | jq empty 2>/dev/null; then
        echo "  ✗ Invalid JSON response from Sensor endpoint"
    else
        sensor_count=$(echo "$sensor_list" | jq -r '.Members | length' 2>/dev/null)
        if [ -n "$sensor_count" ] && [ "$sensor_count" != "null" ] && [ "$sensor_count" -gt 0 ]; then
            echo "  ✓ Sensor endpoint accessible - Found $sensor_count sensors"
            sensor_endpoint_works=true
        else
            echo "  ✗ Sensor endpoint returned no sensors"
        fi
    fi
fi
echo ""

# Step 6: Collect data from available endpoints
timestamp=$(date +%s.%N)
date_str=$(date '+%Y-%m-%d %H:%M:%S')

echo "[6/7] Collecting Power/Sensor data..."
echo "========================================="
echo ""
echo "TIMESTAMP: $timestamp"
echo "DATE: $date_str"
echo "ENDPOINT: $ip"
echo ""

# Display Standard Power endpoint data if available
if [ "$power_endpoint_works" = true ]; then
    echo "========================================="
    echo "STANDARD REDFISH POWER DATA"
    echo "========================================="
    echo ""

    # Parse PowerControl data
    power_control=$(echo "$power_data" | jq -r '
        .PowerControl[]? |
        "PowerControl: \(.Name // .MemberId // "Unknown")
  PowerConsumedWatts: \(.PowerConsumedWatts // "N/A")
  PowerCapacityWatts: \(.PowerCapacityWatts // "N/A")
  PowerLimit: \(.PowerLimit.LimitInWatts // "N/A")"
    ' 2>/dev/null)

    # Check if we have actual power values (not null/N/A)
    has_real_power_data=$(echo "$power_data" | jq -r '
        [.PowerControl[]?.PowerConsumedWatts, .PowerControl[]?.PowerCapacityWatts] |
        map(select(. != null)) | length
    ' 2>/dev/null)

    if [ -n "$power_control" ]; then
        echo "$power_control"
        echo ""
        if [ "$has_real_power_data" -eq 0 ]; then
            echo "⚠️  WARNING: Power values are null (no actual data)"
            echo ""
        fi
    else
        echo "No PowerControl data available"
        echo ""
    fi

    # Parse Voltage sensors
    voltages=$(echo "$power_data" | jq -r '
        .Voltages[]? | select(.ReadingVolts != null) |
        "Voltage: \(.Name // .MemberId // "Unknown")
  ReadingVolts: \(.ReadingVolts)
  Status: \(.Status.State // "Unknown")"
    ' 2>/dev/null)

    if [ -n "$voltages" ]; then
        echo "$voltages"
        echo ""
    fi

    # Parse Power supplies
    power_supplies=$(echo "$power_data" | jq -r '
        .PowerSupplies[]? |
        "PowerSupply: \(.Name // .MemberId // "Unknown")
  PowerOutputWatts: \(.PowerOutputWatts // "N/A")
  PowerCapacityWatts: \(.PowerCapacityWatts // "N/A")
  Status: \(.Status.State // "Unknown")"
    ' 2>/dev/null)

    if [ -n "$power_supplies" ]; then
        echo "$power_supplies"
        echo ""
    fi
fi

# Display BF-3 Sensor data if available
if [ "$sensor_endpoint_works" = true ]; then
    echo "========================================="
    echo "BF-3 SENSOR-BASED API DATA"
    echo "========================================="
    echo ""

    # List all available sensors
    echo "Available Sensors:"
    sensor_names=$(echo "$sensor_list" | jq -r '.Members[]."@odata.id"' 2>/dev/null | sed 's|.*/||')
    echo "$sensor_names" | while read sensor_name; do
        echo "  - $sensor_name"
    done
    echo ""

    # Collect data from key sensors
    echo "Collecting sensor readings..."
    echo ""

    # Power sensors (MOST IMPORTANT for power telemetry)
    echo "--- Power Consumption ---"
    power_sensors=("power_envelope" "soc_power" "power_envelope_deviation")
    for sensor in "${power_sensors[@]}"; do
        sensor_data=$(curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "https://$ip/redfish/v1/Chassis/Card1/Sensors/$sensor" 2>/dev/null)
        if [ $? -eq 0 ] && echo "$sensor_data" | jq empty 2>/dev/null; then
            reading=$(echo "$sensor_data" | jq -r '.Reading // "N/A"' 2>/dev/null)
            units=$(echo "$sensor_data" | jq -r '.ReadingUnits // ""' 2>/dev/null)
            reading_type=$(echo "$sensor_data" | jq -r '.ReadingType // ""' 2>/dev/null)
            if [ "$reading" != "N/A" ] && [ "$reading" != "null" ]; then
                echo "Sensor: $sensor"
                echo "  Type: $reading_type"
                echo "  Reading: $reading $units"
                echo ""
            fi
        fi
    done

    # Temperature sensors
    echo "--- Temperature ---"
    temp_sensors=("bluefield_temp" "ddr_temp" "p0_temp" "p1_temp")
    for sensor in "${temp_sensors[@]}"; do
        sensor_data=$(curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "https://$ip/redfish/v1/Chassis/Card1/Sensors/$sensor" 2>/dev/null)
        if [ $? -eq 0 ] && echo "$sensor_data" | jq empty 2>/dev/null; then
            reading=$(echo "$sensor_data" | jq -r '.Reading // "N/A"' 2>/dev/null)
            units=$(echo "$sensor_data" | jq -r '.ReadingUnits // ""' 2>/dev/null)
            reading_type=$(echo "$sensor_data" | jq -r '.ReadingType // ""' 2>/dev/null)
            if [ "$reading" != "N/A" ] && [ "$reading" != "null" ]; then
                echo "Sensor: $sensor"
                echo "  Type: $reading_type"
                echo "  Reading: $reading $units"
                echo ""
            fi
        fi
    done

    # Voltage sensors
    echo "--- Voltage Rails ---"
    voltage_sensors=("12V_ATX" "12V_PCIe" "VDD" "DVDD" "HVDD" "VDDQ" "3_3V" "1V_BMC")
    for sensor in "${voltage_sensors[@]}"; do
        sensor_data=$(curl --connect-timeout 5 --max-time 10 -k -s -u "$username:$password" "https://$ip/redfish/v1/Chassis/Card1/Sensors/$sensor" 2>/dev/null)
        if [ $? -eq 0 ] && echo "$sensor_data" | jq empty 2>/dev/null; then
            reading=$(echo "$sensor_data" | jq -r '.Reading // "N/A"' 2>/dev/null)
            units=$(echo "$sensor_data" | jq -r '.ReadingUnits // ""' 2>/dev/null)
            reading_type=$(echo "$sensor_data" | jq -r '.ReadingType // ""' 2>/dev/null)
            if [ "$reading" != "N/A" ] && [ "$reading" != "null" ]; then
                echo "Sensor: $sensor"
                echo "  Type: $reading_type"
                echo "  Reading: $reading $units"
                echo ""
            fi
        fi
    done
fi

# Step 7: Display raw JSON and summary
echo "[7/7] Raw Data & Summary..."
echo ""

if [ "$power_endpoint_works" = true ]; then
    echo "========================================="
    echo "Raw Standard Power JSON:"
    echo "========================================="
    echo "$power_data" | jq '.' 2>/dev/null || echo "$power_data"
    echo ""
fi

if [ "$sensor_endpoint_works" = true ]; then
    echo "========================================="
    echo "Raw Sensor List JSON:"
    echo "========================================="
    echo "$sensor_list" | jq '.' 2>/dev/null || echo "$sensor_list"
    echo ""
fi

echo "========================================="
echo "SUMMARY"
echo "========================================="
echo ""
echo "Standard Redfish Power endpoint: $([ "$power_endpoint_works" = true ] && echo "✓ Available" || echo "✗ Not available")"
if [ "$power_endpoint_works" = true ] && [ "$has_real_power_data" -eq 0 ]; then
    echo "  ⚠️  Power values are null - no actual power data"
fi
echo ""
echo "BF-3 Sensor-based API: $([ "$sensor_endpoint_works" = true ] && echo "✓ Available" || echo "✗ Not available")"
if [ "$sensor_endpoint_works" = true ]; then
    echo "  ✓ This endpoint contains actual sensor readings"
fi
echo ""

if [ "$power_endpoint_works" = true ] && [ "$has_real_power_data" -eq 0 ] && [ "$sensor_endpoint_works" = true ]; then
    echo "RECOMMENDATION: Use BF-3 Sensor-based API for this device"
    echo "  The standard Power endpoint exists but returns null values."
    echo "  The sensor-based API provides actual telemetry data."
elif [ "$power_endpoint_works" = true ] && [ "$has_real_power_data" -gt 0 ]; then
    echo "RECOMMENDATION: Standard Power endpoint is working"
    echo "  This device provides power data via standard Redfish API."
elif [ "$sensor_endpoint_works" = true ]; then
    echo "RECOMMENDATION: Use BF-3 Sensor-based API"
    echo "  Standard Power endpoint is not available."
    echo "  Use the sensor-based API for telemetry collection."
fi

echo ""
echo "========================================="
echo "Test completed successfully!"
echo "========================================="
